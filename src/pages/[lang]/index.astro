---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import Header from '../../components/Header.astro'
import Announcement from '../../components/Announcement.astro'
import Hero from '../../components/Hero.astro'
import Features from '../../components/Features.astro'
import Screenshots from '../../components/Screenshots.astro'
import Download from '../../components/Download.astro'
import Footer from '../../components/Footer.astro'
import { getConfig } from '../../utils/config'
import type { Locale } from '../../utils/i18n'
import { localePath } from '../../utils/url'

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }]
}

const { lang } = Astro.params as { lang: Locale }
const config = getConfig()

const allPages = await getCollection('pages')
const navPages = allPages
  .filter((e) => e.id.endsWith(`-${lang}`))
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => {
    const slug = e.id.substring(0, e.id.lastIndexOf('-'))
    return { title: e.data.title, href: localePath(lang, slug) }
  })
---

<Base {config} {lang}>
  <Header {config} {lang} {navPages} />
  <Announcement {config} {lang} />
  <main>
    <Hero {config} {lang} />
    <Features {config} {lang} />
    <Screenshots {config} {lang} />
    <Download {config} {lang} />
  </main>
  <Footer {config} {lang} />
</Base>
