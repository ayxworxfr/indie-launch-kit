---
import { getEntry, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import Header from '../../components/Header.astro'
import Footer from '../../components/Footer.astro'
import { getConfig } from '../../utils/config'
import { useTranslations } from '../../utils/i18n'
import type { Locale } from '../../utils/i18n'

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }]
}

const { lang } = Astro.params as { lang: Locale }
const config = getConfig()
const t = useTranslations(lang)

const entry = await getEntry('pages', `terms-${lang}`)
const rendered = entry ? await render(entry) : null
const Content = rendered?.Content ?? null
---

<Base {config} {lang} title={t('nav.terms')}>
  <Header {config} {lang} />

  <main class="min-h-screen pt-24 pb-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      {
        Content ? (
          <article
            class="prose prose-lg max-w-none
                        prose-headings:font-bold prose-headings:text-gray-900
                        prose-p:text-gray-600 prose-p:leading-relaxed
                        prose-li:text-gray-600"
          >
            <Content />
          </article>
        ) : (
          <div class="text-center py-20">
            <p class="text-gray-400 text-lg">内容文件未找到</p>
            <p class="text-gray-300 text-sm mt-2">
              请添加{' '}
              <code class="bg-gray-100 px-1.5 py-0.5 rounded text-gray-500">
                src/content/pages/terms-{lang}.md
              </code>
            </p>
          </div>
        )
      }
    </div>
  </main>

  <Footer {config} {lang} />
</Base>
