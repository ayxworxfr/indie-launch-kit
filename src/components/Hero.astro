---
import type { AppConfig } from '../utils/config'
import type { Locale } from '../utils/i18n'
import { useTranslations, lv } from '../utils/i18n'

interface Props {
  config: AppConfig
  lang: Locale
}

const { config, lang } = Astro.props
const t = useTranslations(lang)

const { app, download, screenshots } = config
const tagline = lv(app.tagline, lang)
const firstScreenshot = screenshots[0]

const showIos = !!download.ios_url
const showAndroid = !!download.android_url
const showApk = !!download.apk_url
const hasAnyDownload = showIos || showAndroid || showApk
---

<section class="bg-app-gradient relative overflow-hidden">
  <!-- 背景光斑装饰 -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-1/3 -right-1/4 w-[500px] h-[500px] rounded-full bg-white/5 blur-3xl"></div>
    <div class="absolute -bottom-1/3 -left-1/4 w-[500px] h-[500px] rounded-full bg-white/5 blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16 sm:pt-32 sm:pb-20 lg:pt-40 lg:pb-28">
    <div class={`flex flex-col items-center text-center gap-10 ${firstScreenshot ? 'lg:flex-row lg:text-left lg:items-center lg:gap-16' : ''}`}>

      <!-- 文字 + 按钮区 -->
      <div class="flex-1 min-w-0">

        <!-- App 图标 -->
        <div class={`flex mb-6 ${firstScreenshot ? 'justify-center lg:justify-start' : 'justify-center'}`}>
          <img
            src={app.icon}
            alt={app.name}
            class="w-20 h-20 sm:w-24 sm:h-24 rounded-2xl shadow-2xl object-cover"
          />
        </div>

        <!-- App 名称 -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white tracking-tight leading-tight mb-4">
          {app.name}
        </h1>

        <!-- Tagline -->
        <p class="text-lg sm:text-xl text-white/80 leading-relaxed mb-8 max-w-lg mx-auto lg:mx-0">
          {tagline}
        </p>

        <!-- 下载按钮组 -->
        {hasAnyDownload && (
          <div class={`flex flex-wrap gap-3 ${firstScreenshot ? 'justify-center lg:justify-start' : 'justify-center'}`}>
            {showIos && (
              <a href={download.ios_url} class="btn-download-primary" target="_blank" rel="noopener noreferrer">
                <!-- Apple Logo -->
                <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
                {t('hero.ios_download')}
              </a>
            )}
            {showAndroid && (
              <a href={download.android_url} class="btn-download-primary" target="_blank" rel="noopener noreferrer">
                <!-- Android Logo -->
                <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.523 15.341c-.551 0-.999-.449-.999-1s.448-.999.999-.999c.551 0 .999.448.999.999 0 .551-.448 1-.999 1m-11.046 0c-.551 0-.999-.449-.999-1s.448-.999.999-.999c.551 0 .999.448.999.999 0 .551-.448 1-.999 1m11.405-6.02l1.997-3.459a.416.416 0 00-.152-.568.416.416 0 00-.568.152l-2.022 3.503A11.3 11.3 0 0012 7.851a11.3 11.3 0 00-5.137 1.099L4.841 5.447a.416.416 0 00-.568-.152.416.416 0 00-.152.568l1.997 3.459C2.689 11.187.343 14.659 0 18.761h24c-.344-4.102-2.689-7.574-6.118-9.44M10 5H9V4h1zm5 0h-1V4h1z"/>
                </svg>
                {t('hero.android_download')}
              </a>
            )}
            {showApk && (
              <a href={download.apk_url} class="btn-download-ghost" target="_blank" rel="noopener noreferrer">
                <!-- 下载图标 -->
                <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                {t('hero.apk_download')}
              </a>
            )}
          </div>
        )}
      </div>

      <!-- 截图展示区 -->
      {firstScreenshot && (
        <div class="flex-shrink-0">
          <div class="relative">
            <img
              src={firstScreenshot.src}
              alt={lv(firstScreenshot.alt, lang)}
              class="w-52 sm:w-60 lg:w-72 rounded-3xl shadow-2xl"
              loading="eager"
            />
            <!-- 底部渐变遮罩 -->
            <div
              class="absolute bottom-0 left-0 right-0 h-16 rounded-b-3xl
                     bg-gradient-to-t from-black/10 to-transparent pointer-events-none"
              aria-hidden="true"
            ></div>
          </div>
        </div>
      )}

    </div>
  </div>
</section>
