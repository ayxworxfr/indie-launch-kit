---
import type { AppConfig } from '../utils/config'
import type { Locale } from '../utils/i18n'
import { useTranslations } from '../utils/i18n'
import LanguageSwitcher from './LanguageSwitcher.astro'

interface NavPage {
  title: string
  href: string
}

interface Props {
  config: AppConfig
  lang: Locale
  navPages: NavPage[]
}

const { config, lang, navPages } = Astro.props
const t = useTranslations(lang)
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo + App 名称 -->
      <a
        href={`/${lang}/`}
        class="flex items-center gap-2.5 font-bold text-lg text-current
               hover:opacity-80 transition-opacity"
      >
        <!-- 图标：加载失败时显示首字母头像作为兜底 -->
        <img
          src={config.app.logo}
          alt={config.app.name}
          class="w-8 h-8 rounded-lg object-cover"
          onerror="this.style.display='none';this.nextElementSibling.removeAttribute('hidden')"
        />
        <span
          hidden
          class="w-8 h-8 rounded-lg flex-shrink-0 flex items-center justify-center text-white font-bold text-sm"
          style="background: var(--app-gradient)"
          aria-hidden="true">{config.app.name.charAt(0)}</span
        >
        <span>{config.app.name}</span>
      </a>

      <!-- 桌面端导航 -->
      <nav class="hidden md:flex items-center gap-6">
        <a
          href={`/${lang}/`}
          class="text-sm font-medium text-current/85 hover:text-current transition-colors"
        >
          {t('nav.home')}
        </a>
        {
          navPages.map((page) => (
            <a
              href={page.href}
              class="text-sm font-medium text-current/85 hover:text-current transition-colors"
            >
              {page.title}
            </a>
          ))
        }
        <LanguageSwitcher {lang} />
      </nav>

      <!-- 移动端右侧：语言切换 + 汉堡菜单 -->
      <div class="flex md:hidden items-center gap-2">
        <LanguageSwitcher {lang} />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg text-current hover:bg-current/10 transition-colors"
          aria-label={t('nav.menu_open')}
          aria-expanded="false"
          data-label-open={t('nav.menu_open')}
          data-label-close={t('nav.menu_close')}
        >
          <!-- 汉堡图标 -->
          <svg
            id="menu-icon-open"
            class="w-5 h-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <!-- 关闭图标（默认隐藏） -->
          <svg
            id="menu-icon-close"
            class="w-5 h-5 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- 移动端下拉菜单 -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-100 shadow-lg">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col">
      <a
        href={`/${lang}/`}
        class="px-4 py-3 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors"
      >
        {t('nav.home')}
      </a>
      {
        navPages.map((page) => (
          <a
            href={page.href}
            class="px-4 py-3 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors"
          >
            {page.title}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header')!
  const menuBtn = document.getElementById('mobile-menu-btn')!
  const mobileMenu = document.getElementById('mobile-menu')!
  const iconOpen = document.getElementById('menu-icon-open')!
  const iconClose = document.getElementById('menu-icon-close')!

  // 滚动时切换 header 背景样式
  function updateHeaderStyle() {
    if (window.scrollY > 60) {
      header.classList.add('header-scrolled')
    } else {
      header.classList.remove('header-scrolled')
    }
  }
  window.addEventListener('scroll', updateHeaderStyle, { passive: true })
  updateHeaderStyle()

  // 移动端汉堡菜单开关
  const labelOpen = menuBtn.dataset.labelOpen ?? ''
  const labelClose = menuBtn.dataset.labelClose ?? ''

  function setMenuOpen(open: boolean) {
    mobileMenu.classList.toggle('hidden', !open)
    iconOpen.classList.toggle('hidden', open)
    iconClose.classList.toggle('hidden', !open)
    menuBtn.setAttribute('aria-expanded', String(open))
    menuBtn.setAttribute('aria-label', open ? labelClose : labelOpen)
  }

  let menuOpen = false
  menuBtn.addEventListener('click', () => {
    menuOpen = !menuOpen
    setMenuOpen(menuOpen)
  })

  // 点击菜单链接后自动收起
  mobileMenu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false
      setMenuOpen(false)
    })
  })
</script>
