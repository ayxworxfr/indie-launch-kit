---
import type { AppConfig } from '../utils/config'
import type { Locale } from '../utils/i18n'
import { useTranslations } from '../utils/i18n'
import { assetPath } from '../utils/url'

interface Props {
  config: AppConfig
  lang: Locale
}

const { config, lang } = Astro.props
const t = useTranslations(lang)

const { download } = config
const showIos = !!download.ios_url
const showAndroid = !!download.android_url
const showApk = !!download.apk_url
const showQrcode = !!download.qrcode
const hasAnyDownload = showIos || showAndroid || showApk
---

{hasAnyDownload && (
  <section class="bg-app-gradient py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

      <!-- 标题 -->
      <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
        {t('sections.download')}
      </h2>
      <p class="text-white/75 text-lg mb-10">
        {t('sections.download_subtitle')}
      </p>

      <!-- 下载按钮组 -->
      <div class="flex flex-wrap justify-center gap-4 mb-10">
        {showIos && (
          <a href={download.ios_url} class="btn-download-primary" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
            </svg>
            {t('hero.ios_download')}
          </a>
        )}
        {showAndroid && (
          <a href={download.android_url} class="btn-download-primary" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.523 15.341c-.551 0-.999-.449-.999-1s.448-.999.999-.999c.551 0 .999.448.999.999 0 .551-.448 1-.999 1m-11.046 0c-.551 0-.999-.449-.999-1s.448-.999.999-.999c.551 0 .999.448.999.999 0 .551-.448 1-.999 1m11.405-6.02l1.997-3.459a.416.416 0 00-.152-.568.416.416 0 00-.568.152l-2.022 3.503A11.3 11.3 0 0012 7.851a11.3 11.3 0 00-5.137 1.099L4.841 5.447a.416.416 0 00-.568-.152.416.416 0 00-.152.568l1.997 3.459C2.689 11.187.343 14.659 0 18.761h24c-.344-4.102-2.689-7.574-6.118-9.44M10 5H9V4h1zm5 0h-1V4h1z"/>
            </svg>
            {t('hero.android_download')}
          </a>
        )}
        {showApk && (
          <a href={download.apk_url} class="btn-download-ghost" target="_blank" rel="noopener noreferrer">
            <svg class="w-5 h-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            {t('hero.apk_download')}
          </a>
        )}
      </div>

      <!-- 二维码（可选） -->
      {showQrcode && (
        <div class="inline-block bg-white rounded-2xl p-4 shadow-2xl">
          <img
            src={assetPath(download.qrcode)}
            alt={lang === 'zh' ? '扫码下载' : 'Scan to Download'}
            class="w-32 h-32 object-contain"
          />
          <p class="text-gray-400 text-sm mt-2">
            {lang === 'zh' ? '扫码下载' : 'Scan to Download'}
          </p>
        </div>
      )}

    </div>
  </section>
)}
