---
import type { Locale } from '../utils/i18n'

interface Props {
  lang: Locale
}

const { lang } = Astro.props

const otherLang: Locale = lang === 'zh' ? 'en' : 'zh'
const otherLabel = lang === 'zh' ? 'EN' : '中'
const title = lang === 'zh' ? 'Switch to English' : '切换为中文'

// 将当前 URL 路径中的语言前缀替换为目标语言
// 需要先剥离 base 路径前缀，再做语言替换，最后拼回来
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
const currentPath = Astro.url.pathname
const pathWithoutBase = currentPath.startsWith(base) ? currentPath.slice(base.length) : currentPath
const otherPathWithoutBase = pathWithoutBase.replace(new RegExp(`^/${lang}(/|$)`), `/${otherLang}$1`)
const otherPath = base + otherPathWithoutBase
---

<a
  href={otherPath}
  class="lang-switcher-btn inline-flex items-center justify-center
         w-9 h-9 rounded-full border border-current/40
         text-sm font-semibold text-current
         hover:bg-current/10 transition-all duration-200"
  title={title}
  aria-label={title}
>
  {otherLabel}
</a>
